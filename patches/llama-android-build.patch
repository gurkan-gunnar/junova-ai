+static std::string final_answer_only(const std::string &text) {
+    size_t thought_start = text.find("<|channel>thought");
+    if (thought_start == std::string::npos) {
+        thought_start = text.find("<|channel|>thought");
+    }
+    if (thought_start != std::string::npos) {
+        size_t thought_end = text.find("<channel|>", thought_start);
+        size_t marker_size = std::string("<channel|>").size();
+        if (thought_end == std::string::npos) {
+            thought_end = text.find("<|end|>", thought_start);
+            marker_size = std::string("<|end|>").size();
+        }
+        if (thought_end != std::string::npos) {
+            return text.substr(thought_end + marker_size);
+        }
+        return "";
+    }
+
+    const size_t think_start = text.find("<think>");
+    if (think_start != std::string::npos) {
+        const size_t think_end = text.find("</think>", think_start);
+        if (think_end != std::string::npos) {
+            return text.substr(think_end + std::string("</think>").size());
+        }
+        return "";
+    }
+    return text;
+}
+
+static void remember_assistant_answer() {
+    const std::string answer = final_answer_only(assistant_ss.str());
+    if (!answer.empty()) {
+        try {
+            chat_add_and_format(ROLE_ASSISTANT, answer);
+        } catch (const std::exception &error) {
+            LOGe("%s: Could not store assistant answer: %s", __func__, error.what());
+        }
+    }
